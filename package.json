{
  "name": "froggle",
  "private": true,
  "workspaces": [
    "models",
    "engine",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently 'npm run dev:server' 'npm run dev:client'",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "backfill:daily": "tsx scripts/backfillDailyAggregates.ts",
    "rescore:results": "tsx scripts/rescoreResults.ts",
    "email:daily-summary": "tsx scripts/sendDailySummary.ts",
    "calibrate-letters": "tsx scripts/calibrate-letters.ts",
    "tune-quotas": "tsx scripts/tune-quotas.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.2",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "testcontainers": "^12.0.2",
    "vitest": "^4.1.5"
  }
}
